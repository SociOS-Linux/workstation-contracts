            "workdir": "/workspace"
          }
        },
        "steps": [
          {
            "name": "bad-whole-home-mount",
            "run": "sourceosctl agent-machine mounts plan --dev-root $HOME --docs-root ~/Documents/SourceOS/agent-output --downloads-root ~/Downloads/SourceOS/agent-downloads"
          }
